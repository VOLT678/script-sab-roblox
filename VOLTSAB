local function createNeon(size, pos, parent, isButton)
    local container = Instance.new(isButton and "TextButton" or "Frame", parent)
    container.Size = size; container.Position = pos; container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.BackgroundColor3 = Color3.fromRGB(0, 150, 255); container.BorderSizePixel = 0
    if isButton then container.Text = "" end
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 12)
    local grad = Instance.new("UIGradient", container)
    grad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 50, 255)), ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 50, 255))}
    local inner = Instance.new("Frame", container)
    inner.Size = UDim2.new(1, -4, 1, -4); inner.Position = UDim2.new(0, 2, 0, 2); inner.BackgroundColor3 = Color3.fromRGB(15, 15, 15); inner.BorderSizePixel = 0
    Instance.new("UICorner", inner).CornerRadius = UDim.new(0, 10)
    return container, inner, grad
end

