-- [[ SYSTÈME D'ÉCLAIRS RÉALISTES ]]
local function drawLightning()
    local startX = math.random(20, 180)
    local startY = 0
    local segments = 6
    
    for i = 1, segments do
        local endX = startX + math.random(-25, 25)
        local endY = startY + (190 / segments)
        
        local bolt = Instance.new("Frame", lightningCanvas)
        bolt.BackgroundColor3 = Color3.fromRGB(150, 230, 255)
        bolt.BorderSizePixel = 0
        bolt.AnchorPoint = Vector2.new(0.5, 0)
        
        -- Calcul de la distance et de l'angle entre les points
        local dist = math.sqrt((endX - startX)^2 + (endY - startY)^2)
        local angle = math.deg(math.atan2(endY - startY, endX - startX)) - 90
        
        bolt.Size = UDim2.new(0, math.random(1, 3), 0, dist)
        bolt.Position = UDim2.new(0, startX, 0, startY)
        bolt.Rotation = angle
        
        -- Effet de lueur (Glow)
        local glow = Instance.new("ImageLabel", bolt)
        glow.Size = UDim2.new(4, 0, 1.2, 0); glow.Position = UDim2.new(-1.5, 0, -0.1, 0); glow.BackgroundTransparency = 1
        glow.Image = "rbxassetid://6015620050"; glow.ImageColor3 = Color3.fromRGB(0, 150, 255); glow.ImageTransparency = 0.5
        
        tweenService:Create(bolt, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        tweenService:Create(glow, TweenInfo.new(0.3), {ImageTransparency = 1}):Play()
        game:GetService("Debris"):AddItem(bolt, 0.3)
        
        startX, startY = endX, endY
    end
end

